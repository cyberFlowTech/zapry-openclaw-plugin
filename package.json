{
  "name": "zapry-openclaw-plugin",
  "version": "0.1.2",
  "description": "OpenClaw Zapry channel plugin — messaging, groups, feed, clubs, and bot self-management",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyberFlowTech/zapry-openclaw-plugin.git"
  },
  "homepage": "https://github.com/cyberFlowTech/zapry-openclaw-plugin#readme",
  "bugs": {
    "url": "https://github.com/cyberFlowTech/zapry-openclaw-plugin/issues"
  },
  "keywords": [
    "openclaw",
    "zapry",
    "plugin",
    "channel",
    "bot",
    "ai-agent"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openclaw.plugin.json": "./openclaw.plugin.json"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist/",
    "skills/",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
